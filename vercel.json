{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "rm -rf backend/node_modules && npm install && npm install --prefix frontend",
  "framework": "vite",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
